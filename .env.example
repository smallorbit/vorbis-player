# Spotify Configuration
# Get these values from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# For local development, use 127.0.0.1:3000
# For Vercel deployment, use your Vercel domain
VITE_SPOTIFY_REDIRECT_URI=https://your-app-name.vercel.app/auth/spotify/callback

VITE_DROPBOX_CLIENT_ID=your-dropbox-app-key-here

# Last.fm API key for Radio feature
# Get one at https://www.last.fm/api/account/create
VITE_LASTFM_API_KEY=your-lastfm-api-key-here

# Last.fm API secret for Scrobbling (requires user auth)
# Found on the same page as your API key
# Note: this secret is embedded in the client JS bundle (required by Last.fm's auth design).
# Treat it as semi-public; rotate it if you see unexpected API usage.
VITE_LASTFM_API_SECRET=your-lastfm-api-secret-here

# Optional: Environment indicator
NODE_ENV=production